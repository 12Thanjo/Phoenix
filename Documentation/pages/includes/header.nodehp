<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<link rel="icon" type="image/x-icon" href="../../logo.ico">
	<nodehp>
		echoTag("title", "Phoenix Engine | " + data.title);
	</nodehp>
</head>
<style type="text/css">
	html{
		background-color: #18181B;
		color: #D1D5DB;
		padding: 0px;
		margin: 0px;
	}

	body{
		padding: 0px;
		margin: 0px;
		font-size: 17px;
	}


	code{
		background-color: #23241f;
		padding: 3px;
	}

	.code{
		background-color: #23241f;
		padding: 15px;
		font-size: 12px;
		font-family: "Consolas";
	}


	#header{
		position: fixed;
		/*display: flex;*/
		width: 100%;
		height: 55px;
		background-color: #27272A;
		padding: 0px;
	}

	#title{
		font-size: 30px;
		margin: 10px;

		color: #D1D5DB;
		background-color: #27272A;
		border: 0px solid #27272A;
	}

	#container{
		margin-left: 18vw;
		margin-right: 18vw;
		font-size: 30px;
		padding-top: 60px;
		caret-color: transparent;
		font-size: 17px;
	}


	.center{
		display: block;
		margin-left: auto;
		margin-right: auto;
		text-align: center;
	}

	.link{
		color: #22D3EE;
	}

	.link:hover{
		color: #67E8F9;
	}

	.page_link{
		font-size: 24px;
	}

	footer{
		display: block;
		margin-left: auto;
		margin-right: auto;
		text-align: center;

		color: #A1A1AA;
		padding-top: 40px;
		padding-bottom: 20px;
	}

	.footer{
		caret-color: transparent;
		margin: 0px!important;
	}
</style>
<body>
	<link rel="stylesheet" href="../lib/monokai-sublime.min.css">
	<script src="../lib/highlight.min.js"></script>
	<script>hljs.highlightAll();</script>
	<div id="header">
		<button id="title" onclick="window.location = './index.html';">Phoenix Engine</button>
	</div>
	<div id="container">
	