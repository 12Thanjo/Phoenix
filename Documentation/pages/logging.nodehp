</nodehp>


	<h1 class="center">Logging</h1>

	<p style="font-size: 19px;">Phoenix Logging allows for formatted logging to the console, with colors and time-stamps. Thanks to use of macros, Phoenix Logging only logs in debug mode and not in release mode (saving performance). Logs from internal Phoenix are denoted as such.</p>

	

	<h3>Example:</h3>
	<nodehp>
		code(`// set log level to warning or higher
PH_LOG_LEVEL(PH_LOG_WARNING);

int num = 12;

// this will print
PH_WARNING("number: " << num);

// this will not print
PH_INFO("number: " << num);



// set log level to log or higher
PH_LOG_LEVEL(PH_LOG_LOG);

// this will print
PH_INFO("number: " << num);




// Creating a test class to showcase an example implementation of custom printing
class TestClass{
	private:
		int num;

	public:
		TestClass(int p_num) : num(p_num){};
		~TestClass(){};
		void print(){
			std::cout << "[TestClass num: " << num << "]";
		}

};


// overloads operator to allow for printing of TestClass instances
static std::ostream& operator << (std::ostream& os, TestClass& test){
	test.print();
	return os;
}


// create an instance of TestClass with a number value of 12
TestClass test(12);


// print thie instance of TestClass
PH_INFO("Test Print: " << test);`);


		
		br(1);
	</nodehp>

	<p style="font-size: 19px;">The <code>cout</code> type shown down the page is used where <code>std::cout</code> like syntax can be used to form messages.</p>

	<nodehp>

		indentation = 70;


		echoTag("h3", "Functions:");

		create_func("PH_LOG_LEVEL", [param("int", "level")], macro() + "Set the logging level. Options are: <br />" + 
			list(180, ["PH_LOG_LOG", "PH_LOG_INFO", "PH_LOG_WARNING", "PH_LOG_ERROR", "PH_LOG_FATAL"]));

		create_func("PH_ASSERT", [param("bool", "test"), param("cout", "message")], macro() + "Send an error message if a condition isn't true");


		br(1);



		echoTag("h3", "Logging:");

		create_func("PH_LOG",     [param("cout", "message")], macro() + "log to the console at a log level");
		create_func("PH_INFO",    [param("cout", "message")], macro() + "log to the console at a info level");
		create_func("PH_WARNING", [param("cout", "message")], macro() + "log to the console at a warning level");
		create_func("PH_ERROR",   [param("cout", "message")], macro() + "log to the console at a error level");
		create_func("PH_FATAL",   [param("cout", "message")], macro() + "log to the console at a fatal level");
		br(1);
		create_func("PH_TRACE",   [param("cout", "message")], macro() + "log to the console the file and location where this macro is written");
	</nodehp>

